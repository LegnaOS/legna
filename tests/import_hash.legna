import "hash"

legna:
    # hash_int: deterministic, distinct
    let h1 = hash_int(42)
    let h2 = hash_int(43)
    let h3 = hash_int(42)
    let ok = 1
    if h1 == h2:
        ok = 0
    if h1 != h3:
        ok = 0
    output ok
    output "\n"
    # hash_pair
    let p1 = hash_pair(1, 2)
    let p2 = hash_pair(2, 1)
    let p3 = hash_pair(1, 2)
    let ok2 = 1
    if p1 == p2:
        ok2 = 0
    if p1 != p3:
        ok2 = 0
    output ok2
    output "\n"
    # hash_combine
    let c1 = hash_combine(100, 200)
    let c2 = hash_combine(100, 201)
    let ok3 = 1
    if c1 == c2:
        ok3 = 0
    output ok3
    output "\n"
    # hash_mix
    let m1 = hash_mix(1, 2, 3)
    let m2 = hash_mix(3, 2, 1)
    let ok4 = 1
    if m1 == m2:
        ok4 = 0
    output ok4
