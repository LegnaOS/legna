import "bits"

legna:
    # shl / shr
    output shl(1, 0)
    output " "
    output shl(1, 3)
    output " "
    output shl(5, 4)
    output " "
    output shr(80, 4)
    output " "
    output shr(8, 3)
    output "\n"
    # bit_get / bit_set / bit_clear
    output bit_get(10, 1)
    output " "
    output bit_get(10, 2)
    output " "
    output bit_set(8, 1)
    output " "
    output bit_clear(10, 1)
    output "\n"
    # bit_and / bit_or / bit_xor
    output bit_and(12, 10)
    output " "
    output bit_or(12, 10)
    output " "
    output bit_xor(12, 10)
    output "\n"
    # popcount
    output popcount(0)
    output " "
    output popcount(7)
    output " "
    output popcount(255)
