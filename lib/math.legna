fn abs(x):
    if x < 0:
        return 0 - x
    return x

fn min(a, b):
    if a < b:
        return a
    return b

fn max(a, b):
    if a > b:
        return a
    return b

fn clamp(x, lo, hi):
    if x < lo:
        return lo
    if x > hi:
        return hi
    return x

fn pow(base, exp):
    let result = 1
    for i in 0..exp:
        result *= base
    return result
